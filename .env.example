# Database Connection
DATABASE_URL=postgresql://user:password@localhost:5432/real_estate

# Application Environment
NODE_ENV=development

# Session Configuration
SESSION_SECRET=your-secret-key-here-change-in-production

# Payment Configuration
NEXT_PUBLIC_INSTAPAY_ENABLED=true
NEXT_PUBLIC_VODAFONE_CASH_ENABLED=true
NEXT_PUBLIC_BANK_TRANSFER_ENABLED=true

# File Upload (for future production use)
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token

# Email Configuration (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
